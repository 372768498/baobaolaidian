# ─────────────────────────────────────────────
# 宝宝来电 — 环境变量模板
# 复制为 .env 并填入真实值
# ─────────────────────────────────────────────

# 数据库
DATABASE_URL=postgresql+asyncpg://baobao:baobao_dev_2024@localhost:5432/baobao_laidan
SYNC_DATABASE_URL=postgresql://baobao:baobao_dev_2024@localhost:5432/baobao_laidan

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT 认证
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200  # 30天

# LLM（默认 Claude）
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-haiku-4-5-20251001  # 通话阶段低延迟优先

# 语音 STT（阿里云实时语音）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_STT_APP_KEY=

# 语音 TTS（火山引擎）
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_VOICE_TYPE=BV001_streaming  # 默认女声

# 推送通知（Firebase）
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# 应用配置
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# 安全
RISK_GUARD_ENABLED=true
MAX_CALL_DURATION_SECS=1800  # 单次通话最长30分钟
MAX_CALLS_PER_DAY=1           # 每天最多主动来电1次
CALL_RETRY_INTERVAL_MINS=15   # 未接补拨间隔

# 分析埋点（PostHog）
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
