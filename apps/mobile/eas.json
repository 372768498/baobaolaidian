{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "image": "ubuntu-22.04-jdk-17-ndk-r21e"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "image": "ubuntu-22.04-jdk-17-ndk-r21e"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://192.168.2.6:8000",
        "EXPO_PUBLIC_WS_BASE_URL": "ws://192.168.2.6:8000",
        "EXPO_PUBLIC_TTS_PLAYBACK_MODE": "base64"
      }
    },
    "production": {
      "distribution": "store",
      "android": {
        "buildType": "app-bundle",
        "image": "ubuntu-22.04-jdk-17-ndk-r21e"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
