{
  "expo": {
    "name": "宝宝来电",
    "slug": "baobaolaidian",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF5F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.baobaolaidan.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "通话功能需要使用麦克风"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF5F0"
      },
      "package": "com.baobaolaidan.app",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "通话功能需要使用麦克风"
        }
      ]
    ],
    "scheme": "baobao",
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e2d658c7-1e7d-466b-94e2-b80cd55f0f47"
      }
    },
    "owner": "bb372768498s-organization"
  }
}
